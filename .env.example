PORT=3000

# Set to true only for local tests without sending real email.
MAIL_DRY_RUN=false

# SMTP examples:
# Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=465, SMTP_SECURE=true
# Brevo: SMTP_HOST=smtp-relay.brevo.com, SMTP_PORT=587, SMTP_SECURE=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

CONTACT_TO=scaramuzzinomatias@gmail.com
CONTACT_FROM=SmartQ Web <your-email@gmail.com>
